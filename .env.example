# ============================================================
# SpaceCaptain — Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an!
# Einfacher: `bash install.sh` erledigt das automatisch inkl.
# generierter Passwörter — diese Datei ist nur für manuelle Setups.
# ============================================================

# --- Bootstrap-Secrets (zwingend, muessen vor dem ersten Start feststehen) ---

# Datenbank
DB_ROOT_PASSWORD=rootpassword_aendern
DB_NAME=spacecaptain
DB_USER=spacecaptain
DB_PASSWORD=sicheres_passwort_hier

# JWT Auth — Backend startet nicht mit einem Platzhalter/kurzen Wert (< 32 Zeichen)
# Generiere mit: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=bitte_langen_zufaelligen_string_hier_eintragen

# --- Infrastruktur (zwingend, aber selten geaendert) ---

# Ports (nach aussen)
HTTP_PORT=80
HTTPS_PORT=443

# CORS — erlaubte Origins (Protokoll+Host, z.B. https://spacecaptain.example.com)
ALLOWED_ORIGINS=https://localhost

# Zeitzone des Servers (z.B. Europe/Zurich, Europe/Berlin, Europe/Vienna)
TIMEZONE=Europe/Zurich

# --- Optional (haben Standardwerte, meist reicht Konfiguration ueber die UI) ---

# Backup-Verzeichnis (Standard: ./backups im Projektordner)
# NFS-Beispiel: Zuerst NFS-Share auf dem Host mounten, dann hier den Pfad eintragen
# BACKUP_DIR=/mnt/nfs/spacecaptain-backups

# Port des optionalen MCP-Servers (--profile mcp), Standard: 8080
# MCP_PORT=8080

# NFC-Schreibgeraet und Session-Dauer sind KEINE .env-Variablen mehr im
# eigentlichen Sinn: sie werden nur einmalig beim allerersten Start als
# Vorbelegung aus der Umgebung gelesen, landen dann in der DB und sind
# ab da nur noch ueber die UI (Einstellungen) aenderbar. Nicht noetig,
# hier einzutragen — einfach nach der Installation im UI setzen.
# NFC_WRITER_URL=http://nfc-writer.local

# Tailscale-Fernzugriff (--profile tailscale) wird komplett ueber die UI
# aktiviert/konfiguriert (Einstellungen → Fernzugriff) — TS_AUTHKEY/
# TS_HOSTNAME werden dabei automatisch vom Updater-Watcher gesetzt,
# hier manuell einzutragen ist normalerweise nicht noetig.
